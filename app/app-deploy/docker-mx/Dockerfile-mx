# =============================================================================
# 默认在线应用镜像：大模型应用依赖（无 CUDA PyTorch / 无 Ultralytics）
# =============================================================================
# 构建上下文（context）：必须是仓库根目录 models_app_framework
#   docker compose 中已写 context: ../..  relative to app/app-deploy
#
# 包含：
#   - requirements-大模型应用.txt（FastAPI、RAG、ES 客户端、sentence-transformers 等）
#   - app/ 源码
#   - configs/（prompt_registry、small_model 等 YAML 运行时相对工作目录 /workspace）
#
# 不包含：小模型 GPU 推理依赖 → 使用 Dockerfile.small-model-gpu + profile small-model-gpu
# =============================================================================

# FROM python:3.11-slim-bookworm
# 针对沐曦卡服务器，因app-deploy应用中由reranker重排序模型，为了推理速度，基础镜像使用沐曦的AI框架镜像(适配版torch)
FROM cr.metax-tech.com/public-ai-release/maca/vllm-metax:0.17.0-maca.ai3.5.3.307-torch2.8-py312-kylinv11-amd64

# 上述沐曦AI框架基础镜像自带 conda base（含与沐曦栈匹配的 PyTorch / CUDA 运行时），所以需要使用PyTorch / CUDA 运行时，python环境要使用 conda 的 base环境中的python。
# 将 conda 置于 PATH 最前：默认 python、pip、部分工具链与推理依赖一致，避免误用系统 Python。
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/workspace \
    PIP_DEFAULT_TIMEOUT=300 \
    PATH=/opt/conda/bin:${PATH}

WORKDIR /workspace

# 修改为 yum 命令（麒麟/CentOS 系统）
# libxcb：部分音视频栈（如 torchcodec + FFmpeg 4）动态依赖 libxcb.so.1；主修复见 requirements 中 sentence-transformers<5。
RUN yum update -y && \
    yum install -y --setopt=tsflags=nodocs \
    gcc \
    gcc-c++ \
    make \
    libxcb \
    && yum clean all && \
    rm -rf /var/cache/yum

# 勿再 yum/dnf 安装 python3、python3-pip 或把 /usr/bin/python 链到系统 python3：
# 依赖会装进错误环境，运行时若用 conda 解释器则出现「包装在 A、运行在 B」类问题（如 CrossEncoder 找不到 GPU）。

# 构建阶段若出现 json.decoder.JSONDecodeError（解析 PyPI 索引 JSON 失败），多为响应被截断/超时；
# 已加大 pip 超时与重试。仍不稳定时可指定镜像，例如：
#   docker compose build --build-arg PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple \
#     --build-arg PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
ARG PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
ARG PIP_TRUSTED_HOST=mirrors.aliyun.com

COPY requirements-大模型应用.txt /workspace/requirements-app.txt
# 显式使用 conda 的 pip，与下文 CMD / compose 中的 /opt/conda/bin/python 为同一 site-packages。
RUN /opt/conda/bin/pip install --upgrade pip setuptools wheel \
    && /opt/conda/bin/pip install --no-cache-dir --timeout=300 --retries=15 \
        ${PIP_INDEX_URL:+-i} ${PIP_INDEX_URL:+$PIP_INDEX_URL} \
        ${PIP_TRUSTED_HOST:+--trusted-host} ${PIP_TRUSTED_HOST:+$PIP_TRUSTED_HOST} \
        -r /workspace/requirements-app.txt

COPY app /workspace/app
COPY configs /workspace/configs

EXPOSE 8083

# 生产 worker 数由 compose command 传入；此仅为镜像默认入口。
# 使用 python -m uvicorn（而非 PATH 上可能来自其他层的 uvicorn 可执行文件）保证与 conda 解释器一致。
CMD ["/opt/conda/bin/python", "-m", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8083"]
