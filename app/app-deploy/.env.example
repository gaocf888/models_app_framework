# =============================================================================
# 应用部署环境变量模板（请复制为同目录 .env 再修改）
# =============================================================================
#
# 【重要】两套消费者 · 配置时不要混用语义
#
#   (1) Docker Compose 在「宿主机」解析（写进 docker-compose.yml 的 ${VAR}）
#       仅影响 compose 本身：端口映射、external 网络名、数据卷源路径、
#       models-app-gpu 的 NVIDIA_VISIBLE_DEVICES 注入值 等。
#       见本文件末尾「━━ Compose 专用 ━━」段。
#
#   (2) 应用进程在「容器内」读取（app/core/config.py 的 os.getenv）
#       通过 compose 的 env_file 整文件注入，应用不会自行 load_dotenv 读磁盘。
#       密钥、LLM/RAG/DB 等均以容器内环境为准。
#
# 【策略】
#   - 开发：本目录一份 .env，勿提交真实密码。
#   - 生产：用 CI/Secret 注入相同键名，或挂载只读 env；与 EasySearch、vLLM 侧配置保持一致。
#   - 与 rag_db-deploy 对齐：RAG_ES_* 与 project-env/rag-es.env.example、库侧账号一致。
#
# =============================================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 入口与并发（由 config.py / uvicorn 使用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用部署环境标记（当前仅作为配置元数据，代码未做 dev/prod 分支逻辑）
APP_ENV=prod
# Uvicorn worker 数量；docker-compose 内 command 使用 UVICORN_WORKERS
UVICORN_WORKERS=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 日志
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LOG_LEVEL=INFO
LOG_JSON=false
# stdout 日志（Docker logs）保持启用；以下参数用于额外开启应用内部文件日志（按大小轮转）
LOG_FILE_ENABLED=true
# 默认文件路径（容器内）；开启 LOG_FILE_ENABLED=true 时生效
LOG_FILE=/workspace/logs/app.log
# 单个日志文件最大字节数（默认 100MB）
LOG_FILE_MAX_BYTES=104857600
# 保留的历史文件数（不含当前 app.log）
LOG_FILE_BACKUP_COUNT=10
# 轮转后的历史日志是否 gzip 压缩
LOG_FILE_COMPRESS=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 鉴权（Service API Key，对方后台调用算法接口时使用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 请求头：Authorization: Bearer <密钥>；支持轮换：逗号分隔多个等效密钥（任一匹配即可）。
#
# 【生成密钥】在仓库根目录用 Python 调用 app/auth/keygen.py 中的 generate_service_api_key（勿提交真实值到 Git）：
#   Linux/macOS: PYTHONPATH=. python -c "from app.auth.keygen import generate_service_api_key; print(generate_service_api_key())"
#   Win PS:       $env:PYTHONPATH=(Get-Location).Path; python -c "from app.auth.keygen import generate_service_api_key; print(generate_service_api_key())"
# 部署与轮换说明：同目录 README.md、README-simple-deploy.md「Service API Key」小节。
# 认证与安全总述：仓库内 docs/Service-API-Key-认证与安全说明.md
# 支持配置多个 API key：英文逗号分隔（请求携带的密钥与下列任一项一致即可通过）。
SERVICE_API_KEYS=WOeJlenXrXN-CjjBEnGElXtnH0JY2h-i5tt7XIAa4iM,kCRA4fZs72cqc9C_oznxn_HWUeT-CDf1MP2uHvr_ihQ
# 单密钥时可改用：SERVICE_API_KEY=...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 大模型（统一指向 vllm-deploy，OpenAI 兼容 /v1）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 必须使用「容器间」可解析主机名：默认 vllm-service，勿用 127.0.0.1 指宿主机上的 vLLM
LLM_DEFAULT_MODEL=qwen2.5-vl-32b-instruct-awq
# OpenAI 兼容根路径（结尾保留 /v1）
LLM_DEFAULT_ENDPOINT=http://vllm-service:8000/v1
# 若 vLLM 开启 API Key，在此配置；未启用可留空
LLM_DEFAULT_API_KEY=
# 若 vLLM 启用了 api-key，在此与 vLLM 侧填相同值

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · EasySearch / RAG（与 rag_db-deploy、HTTPS/TLS 策略一致）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RAG_VECTOR_STORE_TYPE=es
# 可配置多个主机，逗号分隔，如：https://rag-easysearch:9200,https://rag-es-backup:9200
RAG_ES_HOSTS=https://rag-easysearch:9200
# EasySearch 账号（与 rag_db-deploy/.env 保持一致）
RAG_ES_USERNAME=admin
# EasySearch 密码（与 rag_db-deploy/.env 保持一致）
RAG_ES_PASSWORD=ChangeMe_123!
# 若使用 API Key，可替代账号密码；留空表示不用
RAG_ES_API_KEY=
# 自建证书 / 内网 HTTPS 时常为 false；公网受信 CA 可改为 true
RAG_ES_VERIFY_CERTS=false
# ES/EasySearch 请求超时（秒）
RAG_ES_REQUEST_TIMEOUT=30

# 主知识库索引（chunks）
RAG_ES_INDEX_NAME=rag_knowledge_base
# 主知识库别名（应用查询通常走 alias）
RAG_ES_INDEX_ALIAS=rag_knowledge_base
# 索引版本号（用于迁移）
RAG_ES_INDEX_VERSION=2
# 启动时是否自动检查并迁移索引版本
RAG_ES_AUTO_MIGRATE_ON_START=true
# 向量字段名（需与摄入/查询逻辑一致）
RAG_ES_VECTOR_FIELD=embedding
# 文档元信息索引（文档级状态、来源、版本等）
RAG_ES_DOCS_INDEX_NAME=rag_docs
RAG_ES_DOCS_INDEX_ALIAS=rag_docs_current
RAG_ES_DOCS_INDEX_VERSION=1
# 异步作业索引（摄入任务、状态追踪等）
RAG_ES_JOBS_INDEX_NAME=rag_jobs
RAG_ES_JOBS_INDEX_ALIAS=rag_jobs_current
RAG_ES_JOBS_INDEX_VERSION=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · Redis 会话（compose 服务名 redis，勿写成 127.0.0.1）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://redis:6379/0
# 会话过期时间（分钟），0 或负数可视为不过期（按代码实现）[redis 会话热存储7天(10080分钟)]
CONV_SESSION_TTL_MINUTES=10080
# 单会话最大保留消息数（超出会裁剪历史）
CONV_MAX_HISTORY_MESSAGES=50
# GET /chatbot/sessions/messages 单次最多返回消息条数（导出/历史）
CONV_EXPORT_MAX_MESSAGES=500
# GET /chatbot/sessions 每页条数默认与硬顶（1~200）
CONV_SESSION_LIST_MAX=50
# 会话列表标题：off=仅用预览/session_id；truncate=首条 user 截断；llm=预留（当前与 truncate 相同）
CHATBOT_SESSION_TITLE_MODE=truncate
# 用户 PATCH 修改标题时的最大码位长度（默认 64，上限 200）
# CHATBOT_SESSION_TITLE_EDIT_MAX_RUNES=64
# 截断标题最大字符数（Unicode 码位）
CHATBOT_SESSION_TITLE_MAX_RUNES=28
# user_id / session_id：默认禁止 ':' 与控制字符（见 app/conversation/ids.py）；遗留 ID 可设 CONV_ID_STRICT=false
CONV_ID_STRICT=true
CONV_USER_ID_MAX_LEN=128
CONV_SESSION_ID_MAX_LEN=256
# Redis 写入后阻塞等待落盘（毫秒，0=仅异步）；生产可设 300~2000 以降低「写完立刻读」竞态
CONV_REDIS_APPEND_WAIT_MS=0
# Redis 客户端超时与健康检查（秒）；HEALTH_CHECK_INTERVAL=0 表示关闭（旧版 redis-py 可能不支持 interval）
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_HEALTH_CHECK_INTERVAL=30
# 会话冷层归档（EasySearch）与自动回查
# 开启后：append_* 自动写入冷层；/chatbot/sessions* 在热层不足时自动补查冷层
CONV_ARCHIVE_ENABLED=true
CONV_QUERY_FALLBACK_COLD=true
# 默认复用 RAG_ES_* 连接；如需独立归档集群可单独配置 CONV_ARCHIVE_ES_*
CONV_ARCHIVE_ES_INDEX=conversation_messages_v1
CONV_ARCHIVE_ES_SESSIONS_INDEX=conversation_sessions_v1
CONV_ARCHIVE_QUERY_MAX_LIMIT=2000
# CONV_ARCHIVE_ES_HOSTS=https://rag-easysearch:9200
# CONV_ARCHIVE_ES_USERNAME=admin
# CONV_ARCHIVE_ES_PASSWORD=ChangeMe_123!
# CONV_ARCHIVE_ES_API_KEY=
# CONV_ARCHIVE_ES_VERIFY_CERTS=false
# CONV_ARCHIVE_ES_TIMEOUT_SECONDS=10
# 对象存储备份增强（local 或 s3；默认 local）
CONV_ARCHIVE_OBJECT_ENABLED=true
CONV_ARCHIVE_OBJECT_BACKEND=local
CONV_ARCHIVE_OBJECT_LOCAL_DIR=/workspace/data/conversation_archive
# S3 兼容对象存储（当 BACKEND=s3 且容器安装 boto3 时生效）
# CONV_ARCHIVE_OBJECT_S3_ENDPOINT=http://minio:9000
# CONV_ARCHIVE_OBJECT_S3_ACCESS_KEY=minioadmin
# CONV_ARCHIVE_OBJECT_S3_SECRET_KEY=minioadmin
# CONV_ARCHIVE_OBJECT_S3_REGION=us-east-1
# CONV_ARCHIVE_OBJECT_S3_BUCKET=conversation-archive
# CONV_ARCHIVE_OBJECT_S3_PREFIX=conversation-archive

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 智能客服 LangGraph（可选，未配置时使用代码默认值）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 是否启用 LangGraph 编排主链路（建议生产保持 true）
CHATBOT_GRAPH_ENABLED=true
# 是否启用意图节点（输出 kb_qa / clarify / data_query 等，由白名单约束）
CHATBOT_INTENT_ENABLED=true
# 意图节点允许输出的标签白名单（逗号分隔）；data_query 走 NL2SQL，kb_qa 走向量 RAG
CHATBOT_INTENT_OUTPUT_LABELS=kb_qa,clarify,data_query
# 是否允许将问句判为 data_query 并走智能客服内嵌 NL2SQL（需业务库已配置）
CHATBOT_NL2SQL_ROUTE_ENABLED=true
# 未传 prompt_version 时使用的 chatbot 模板版本（configs/prompts.yaml）
CHATBOT_PROMPT_DEFAULT_VERSION=boiler_v1
# 是否在结束 meta 中生成关联推荐问句（规则+RAG片段+LLM）
CHATBOT_SUGGESTED_QUESTIONS_ENABLED=true
CHATBOT_SUGGESTED_QUESTIONS_MAX=5
# 是否启用 C-RAG（检索质量不足时重试改写）
CHATBOT_CRAG_ENABLED=true
# C-RAG 最大重试次数（含首轮后额外重试）
CHATBOT_CRAG_MAX_ATTEMPTS=2
# 检索质量阈值（0~1）；低于阈值触发重试或澄清
CHATBOT_CRAG_MIN_SCORE=0.55
# RAG 主引擎：agentic 或 hybrid
CHATBOT_RAG_ENGINE_MODE=agentic
# 主引擎失败时回退引擎
CHATBOT_RAG_ENGINE_FALLBACK=hybrid
# 会话历史读取条数（图中上下文窗口）
CHATBOT_HISTORY_LIMIT=20
# 图片预处理开关：在 ChatbotService 入口前对 image_urls 执行下载+缩放+压缩+存储（minio/local）
CHATBOT_IMAGE_PREPROCESS_ENABLED=true
# 图片最长边（像素）：超过该值会等比缩放（推荐 1024~1600）
CHATBOT_IMAGE_MAX_EDGE=1280
# 原图大小超过该阈值（MB）才启用更强有损压缩
CHATBOT_IMAGE_COMPRESS_THRESHOLD_MB=2
# 有损压缩 JPEG 质量（1~95，默认 80）
CHATBOT_IMAGE_JPEG_QUALITY=80
# 图片存储后端（minio 或 local）。推荐 minio：多实例共享，且给 vLLM 提供可访问 URL。
CHATBOT_IMAGE_STORAGE_BACKEND=minio
# 本地存储目录（相对 app 目录或绝对路径）
CHATBOT_IMAGE_STORE_DIR=runtime/chatbot_images
# 静态访问前缀（由 main.py 挂载），历史会话可回显该路径图片
CHATBOT_IMAGE_PUBLIC_PATH=/chatbot/media
# MinIO（image_storage_backend=minio 时生效）
CHATBOT_IMAGE_MINIO_ENDPOINT=models-app-minio:9000
CHATBOT_IMAGE_MINIO_ACCESS_KEY=minioadmin
CHATBOT_IMAGE_MINIO_SECRET_KEY=minioadmin123
CHATBOT_IMAGE_MINIO_BUCKET=chatbot-images
CHATBOT_IMAGE_MINIO_SECURE=false
CHATBOT_IMAGE_MINIO_AUTO_CREATE_BUCKET=true
# 预签名 URL 过期秒数（vLLM 拉图使用；建议 5~30 分钟）
CHATBOT_IMAGE_MINIO_PRESIGN_TTL_SECONDS=900
# 客户端断开时是否落库 partial assistant 消息
CHATBOT_PERSIST_PARTIAL_ON_DISCONNECT=true
# 图运行异常时是否回退到旧链路（预留开关，当前实现以日志与降级为主）
CHATBOT_FALLBACK_LEGACY_ON_ERROR=true
# 查询改写最大长度（防止 C-RAG 改写膨胀）
MAX_REWRITE_QUERY_LENGTH=256
# 图执行总时长预算（毫秒）
MAX_GRAPH_LATENCY_MS=60000
# LangGraph 图状态 checkpoint（与下方「综合分析 ANALYSIS_CHECKPOINT_*」语义一致）
# CHATBOT_CHECKPOINT_BACKEND：取值 none | memory | redis（大小写不敏感；非法值会按 none 处理）
#   - none：不持久化图状态（默认，生产无多轮续跑需求时推荐）
#   - memory：进程内 MemorySaver，重启丢失，仅开发/单机调试
#   - redis：需 langgraph.checkpoint.redis + 有效 URL；用于多 worker/断点语义（与智能客服会话 thread 策略配合时再启用）
CHATBOT_CHECKPOINT_BACKEND=none
# 仅当 CHATBOT_CHECKPOINT_BACKEND=redis 时必填；与 REDIS_URL 可同实例不同 DB（如 /1），或独立 Redis
# 示例：redis://redis:6379/1
# CHATBOT_CHECKPOINT_REDIS_URL=redis://redis:6379/1
# 逻辑命名空间（日志与运维识别用；不改变 Redis URL 本身）
CHATBOT_CHECKPOINT_NAMESPACE=chatbot_graph

# 锅炉/管材故障域 + 相似案例（限定 namespace RAG，默认关闭；见 enterprise 文档 §14）
# CHATBOT_SIMILAR_CASE_ENABLED=false
# 与知识库摄入时的 namespace 一致（可改为任意业务名）
# CHATBOT_SIMILAR_CASE_NAMESPACE=事故案例
# CHATBOT_SIMILAR_CASE_TOP_K=5
# CHATBOT_FAULT_DETECT_ENABLED=true
# 是否允许用图片参与故障判定（无图时仅文本）；请求体 enable_fault_vision 可覆盖
# CHATBOT_FAULT_VISION_ENABLED=true
# rules | llm | hybrid（关键词命中或 LLM/多模态 JSON 判定）
# CHATBOT_FAULT_DETECT_MODE=hybrid
# LLM 判定 fault_related 时的最低 confidence（0~1）
# CHATBOT_FAULT_MIN_CONFIDENCE=0.5

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 业务库（NL2SQL 等）— DB_URL 优先于 DB_* 拼接（见 config.py）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MySQL 在宿主机：compose 已加 extra_hosts host.docker.internal
DB_HOST=124.222.37.179
DB_USER=root
DB_PASSWORD=1qaz@4321
DB_NAME=boiler
# 未设置 DB_URL 时，由 DB_USER/DB_PASSWORD 等拼接的连接串会对用户名、密码做 URL 编码（密码含 @ 等也安全）。
# 若手写 DB_URL，则须自行编码：例如密码 1qaz@4321 -> 1qaz%404321
# DB_URL=mysql+aiomysql://root:1qaz%404321@host.docker.internal:3306/aishare

# NL2SQL：默认使用的 prompts.yaml 中 nl2sql 模板版本（v2 含 {{NL2SQL_SCHEMA_CATALOG}} 全库表注入）
# NL2SQL_PROMPT_DEFAULT_VERSION=v2
# 注入到提示词中的表/列数量上限（防止上下文过长）
# NL2SQL_SCHEMA_CATALOG_MAX_TABLES=400
# NL2SQL_SCHEMA_CATALOG_MAX_COLS=48
# nl2sql_schema 命名空间单独多召回几条 chunk（总表+字段表不易同片命中）
# NL2SQL_SCHEMA_NAMESPACE_TOP_K=12
# NL2SQL 各命名空间 RAG 片段上限（推理更稳、Prompt 更短；调大则更接近旧行为）
# NL2SQL_RAG_MAX_SCHEMA_CHUNKS=8
# NL2SQL_RAG_MAX_BIZ_CHUNKS=4
# NL2SQL_RAG_MAX_QA_CHUNKS=4
# NL2SQL 生成 SQL 专用采样参数（与全局 LLM_DEFAULT 解耦；降低同题 SQL 漂移）
# NL2SQL_CHAT_TEMPERATURE=0
# NL2SQL_CHAT_TOP_P=0.95
# 若 vLLM/OpenAI 兼容服务支持固定种子可填整数（可选）
# NL2SQL_CHAT_SEED=
# DB 反射成功时跳过规划 LLM，减少虚构表名对 RAG 查询的干扰（true/false）
# NL2SQL_DISABLE_PLANNER_WHEN_DB_SCHEMA=true
# 执行前先 EXPLAIN，提前拦截语法/未知列等（略增延迟；true/false，注释掉或未配置时，程序默认 false）
# NL2SQL_EXPLAIN_BEFORE_EXECUTE=false

# SELECT 或 EXPLAIN 失败时是否调用 LLM 按错误信息修正 SQL（需 LangChain；true/false，注释掉或未配置时，程序默认 true）
# NL2SQL_REFINE_ON_EXEC_ERROR=true
# 上述执行失败闭环的最大修正次数（每次成功产出新 SQL 会再跑 EXPLAIN+SELECT）
# NL2SQL_MAX_EXEC_REFINES=1

# 业务实体规则：JSON 数组，或 NL2SQL_ENTITY_RULES_FILE 指向 JSON 文件。示例见下方注释块。
# NL2SQL_ENTITY_RULES=
# NL2SQL_ENTITY_RULES_FILE=/path/to/nl2sql_entity_rules.json
# 示例（单行 JSON）：当问题含「一号锅炉」且 SQL 里出现 mill_name='一号锅炉' 时判违规
# NL2SQL_ENTITY_RULES=[{"question_contains_any":["一号锅炉"],"sql_pattern":"(?i)mill_name\\s*=\\s*'[^']*一号锅炉","message":"锅炉名称不应写在 mill_name 上，请用 account_boiler.boiler_name 等台账字段"}]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 嵌入与重排（HF 缓存卷见 docker-compose huggingface-cache）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# 优先使用本地模型目录（离线部署推荐）；设置后优先于 EMBEDDING_MODEL_NAME
# EMBEDDING_MODEL_PATH=/models/bge-small-zh-v1.5
EMBEDDING_MODEL_PATH=/workspace/models/embeddings/bge-small-zh-v1.5
RAG_RERANKER_MODEL_NAME=BAAI/bge-reranker-large
# 本地重排模型路径（离线部署推荐）；设置后优先于 RAG_RERANKER_MODEL_NAME
# 必须为已存在的目录（内含 CrossEncoder 所需文件）；若路径无效则自动回退到 RAG_RERANKER_MODEL_NAME，避免把绝对路径误当 HF repo id
# RAG_RERANKER_MODEL_PATH=/workspace/models/rerank/bge-reranker-large
# 可选：显式指定 reranker 推理设备（例如 cpu / cuda / cuda:1）。
# 未设置时由 sentence-transformers 自动选择设备（常见为 cuda:0 或 cpu）。
RAG_RERANKER_DEVICE=cuda:1
# RAG_RERANKER_TRUST_REMOTE_CODE=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · RAG 行为（更多键见 app/core/config.py）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RAG_ENABLE_BY_DEFAULT=true
# 上下文开关默认值（接口请求未显式传参时生效）
RAG_ENABLE_CONTEXT_BY_DEFAULT=true
# 传统检索 TopK（各场景还可被 scene 配置覆盖）
RAG_TOP_K=5

# 摄入 content 为 http(s) 文件 URL 时拉取（默认关闭；生产务必配白名单）
# RAG_CONTENT_FETCH_ENABLED=false
RAG_CONTENT_FETCH_ENABLED=true
RAG_CONTENT_FETCH_MAX_BYTES=314572800
RAG_CONTENT_FETCH_TIMEOUT_S=600
# 非空时仅允许列表内主机（逗号分隔）；支持 *.suffix.com 匹配子域
# RAG_CONTENT_FETCH_ALLOW_HOSTS=files.example.com,cdn.example.com
RAG_CONTENT_FETCH_BLOCK_PRIVATE=true
# RAG_CONTENT_FETCH_BEARER_TOKEN=
# RAG_CONTENT_FETCH_HEADER_NAME=
# RAG_CONTENT_FETCH_HEADER_VALUE=
# 启动时是否自动回收“僵尸 RUNNING”摄入任务（上次重启中断后残留）
RAG_RECOVER_STUCK_RUNNING_ON_STARTUP=true
# RUNNING 超过该秒数未更新则判定卡死并转 FAILED（默认 30 分钟）
RAG_RUNNING_STUCK_TIMEOUT_SECONDS=1800
# 是否启用混合检索（语义 + 关键词 + RRF + 重排）
RAG_HYBRID_ENABLED=true
# 是否启用 Agentic 检索策略（多步规划检索）
RAG_AGENTIC_ENABLED=true
# 场景化 TopK / 混合检索子参数（可选；未设置则用代码默认值）。
# 综合分析「结论前」业务 RAG 使用 scene=analysis（`AnalysisGraphRunner._retrieve_business_rag`）：
# RAG_SCENE_ANALYSIS_TOP_K=8
# RAG_SCENE_ANALYSIS_SEMANTIC_TOP_K=32
# RAG_SCENE_ANALYSIS_KEYWORD_TOP_K=32
# RAG_SCENE_ANALYSIS_RERANK_TOP_N=16
# 综合分析「规划前」schema/口径类检索使用 scene=nl2sql（`AnalysisGraphRunner._retrieve_plan_rag` → plan_context_rag）：
# RAG_SCENE_NL2SQL_TOP_K=5
# RAG_SCENE_NL2SQL_SEMANTIC_TOP_K=20
# RAG_SCENE_NL2SQL_KEYWORD_TOP_K=20
# RAG_SCENE_NL2SQL_RERANK_TOP_N=12
# 其它 scene：chatbot / llm_inference 及默认值见 `app/core/config.py` → `RAGSceneProfilesConfig`

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · MinerU（mineru-deploy 独立栈；须与 docker-compose 中 mineru-external 同时使用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 是否启用 MinerU 解析（接入代码落地后生效；未实现前保持 false）
MINERU_ENABLED=true
# 容器内访问 mineru-api：端口必须是 MinerU 容器内监听端口（本栈为 8000），与 vLLM 容器内 8000 不冲突
# 勿使用宿主机映射端口 MINERU_PORT（如 8009）；详见 mineru-deploy/README.md §7
MINERU_BASE_URL=http://mineru-api:8000
# 单次解析 HTTP 超时（秒）；大扫描 PDF 建议 600～3600，按 SLA 调整
MINERU_TIMEOUT_S=3600
# 应用侧并发调用上限（保护同机资源；与 mineru-deploy 内并发策略对齐）
MINERU_MAX_CONCURRENT=1
# 应用容器内与 mineru-deploy 共享 IO 的挂载点（与 docker-compose 中卷目标路径一致）
MINERU_IO_CONTAINER_PATH=/workspace/mineru-io
# mineru-api /file_parse 表单：backend、parse_method（扫描件建议 ocr）、语言
MINERU_BACKEND=pipeline
MINERU_PARSE_METHOD=ocr
MINERU_LANGUAGE=ch
# CPU 压力控制：可关闭高开销模块（复杂公式/表格）
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
# 大 PDF 分段解析：0=不分段；建议先从 50~100 页/批试起
MINERU_PAGE_BATCH_SIZE=30
# 抽样页平均可提取字符低于该阈值则视为扫描 PDF，走 MinerU（文字 PDF 仍走 pypdf）
MINERU_PDF_SCANNED_MAX_AVG_CHARS=40
# 多 worker 时与 REDIS_URL 配合的全局并发池键前缀
MINERU_REDIS_SEM_KEY_PREFIX=mineru:ingest
# 一般无需修改
# MINERU_FILE_PARSE_PATH=/file_parse
# 与 mineru-deploy 中 MINERU_API_OUTPUT_ROOT 最后一级目录一致（共享 IO 卷上的子目录名）
# MINERU_DISK_FALLBACK_SUBDIR=mineru-output

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · GraphRAG（默认关；需独立 Neo4j 时再配置）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GRAPH_RAG_ENABLED=false
# Neo4j Bolt 地址（容器间建议使用服务名）
# NEO4J_URI=bolt://graph-neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 可观测性（可选）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · FAISS 向量库（与 ES 二选一；开发单机可用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAG_VECTOR_STORE_TYPE=faiss
# RAG_FAISS_INDEX_DIR=/data/faiss

## =============================================================================
## ━━ Compose 专用（宿主机解析；勿与「仅应用读取」混淆）━━━━━━━━━━━━━━━━━━━━
## =============================================================================
## 下列变量在 docker-compose.yml 中通过 ${VAR:-默认值} 使用；不会自动被 app/core/config.py 使用，
## 除非同时作为普通环境变量注入容器（Compose env_file 会整份注入，应用若「恰巧」同名才会读到——
## 下列键名仅为避免冲突，与业务无关，应用代码可忽略）。
##
## APP_PORT                models-app 映射到宿主机的端口
## APP_PORT_GPU            models-app-gpu 映射到宿主机的端口（profile small-model-gpu）
## VLLM_DOCKER_NETWORK     已存在的 Docker 网络名，用于连接 vLLM
## RAG_DOCKER_NETWORK      已存在的 Docker 网络名，用于连接 EasySearch
## MINERU_DOCKER_NETWORK   已存在的 Docker 网络名，用于连接 mineru-api（mineru-deploy）
## MINERU_IO_HOST_PATH     宿主机目录，与 mineru-deploy 的 MINERU_IO_HOST_PATH 必须相同；
##                         bind 到应用容器 MINERU_IO_CONTAINER_PATH（默认 /workspace/mineru-io）
## GRAPH_DOCKER_NETWORK    已存在的 Docker 网络名，用于连接 Neo4j（GraphRAG）
## EMBEDDING_MODELS_HOST_PATH
##                         宿主机绝对路径（根目录）→ 组合挂载 ${EMBEDDING_MODELS_HOST_PATH}/bge-small-zh-v1.5
## RERANKER_MODELS_HOST_PATH
##                         宿主机绝对路径（根目录）→ 组合挂载 ${RERANKER_MODELS_HOST_PATH}/bge-reranker-large
## SMALL_MODEL_WEIGHTS_HOST_PATH
##                         宿主机绝对路径 → 只读挂载到 GPU 容器 /workspace/models/small
## SMALL_MODEL_NVIDIA_VISIBLE_DEVICES
##                         传入 GPU 容器的 NVIDIA_VISIBLE_DEVICES（默认 all）
## MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
##                         MinIO 管理员账号（用于创建 bucket/控制台登录）
## MINIO_PORT / MINIO_CONSOLE_PORT
##                         MinIO API/Console 映射到宿主机端口
## =============================================================================

APP_PORT=8083

# 须在「已存在」的外部网络；与 vllm-deploy、rag_db-deploy 实际名称一致（docker network ls）
VLLM_DOCKER_NETWORK=docker_vllm-network
RAG_DOCKER_NETWORK=ai-stack
# MinerU 外部网络名，须与 mineru-deploy/.env 中 MINERU_NETWORK_NAME 一致（docker network ls 可见）。
# 若尚未部署 mineru-deploy，可先占位：docker network create mineru-stack
MINERU_DOCKER_NETWORK=mineru-stack
# 与 mineru-deploy/.env 中 MINERU_IO_HOST_PATH 保持一致（Linux 示例）；未配置时使用 compose 占位卷 mineru-io-dummy
# MINERU_IO_HOST_PATH=/aidata/mineru/io
# GraphRAG / Neo4j 外部网络名，需与 graphrag_db-deploy/.env 中 NEO4J_NETWORK 一致
GRAPH_DOCKER_NETWORK=graph-stack
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# RAG 离线模型宿主机路径（推荐统一路径约定）
EMBEDDING_MODELS_HOST_PATH=/aidata/models/embeddings
RERANKER_MODELS_HOST_PATH=/aidata/models/reranker

# ---------- profile: small-model-gpu（docker compose --profile small-model-gpu）----------
# GPU 版 API 对外端口（避免与 APP_PORT 冲突）
APP_PORT_GPU=8081
# 仅起 GPU 实例且占 8080：先 stop models-app，再设 APP_PORT_GPU=8080
SMALL_MODEL_NVIDIA_VISIBLE_DEVICES=all
# 示例 Linux：SMALL_MODEL_WEIGHTS_HOST_PATH=/opt/small-model-weights
# 示例 Windows：SMALL_MODEL_WEIGHTS_HOST_PATH=F:/weights/small
# 不设置或整行不写：compose 使用占位卷 small-model-weights-dummy（无真实权重，仅便于调试 compose）



# =============================================================================
# 应用进程 · 综合分析 Analysis（`app/core/config.py` → `AnalysisConfig`）
# =============================================================================
# 【概念区分】
#   - Trace 归档（ANALYSIS_TRACE_*）：HTTP 管理端列表/详情/统计用的「分析结果 JSON」持久化，实现见
#     `app/services/analysis_trace_store.py` → `create_analysis_trace_store`。
#   - LangGraph checkpoint（ANALYSIS_CHECKPOINT_*）：单次请求内图节点状态的「可选」持久化，与 Trace 无关；
#     编译逻辑见 `AnalysisGraphRunner._build_analysis_checkpointer`（与智能客服 `CHATBOT_CHECKPOINT_*` 语义类似）。
#   - 提示词：默认文件 `configs/prompts.yaml`，由 `PromptTemplateRegistry` 加载；业务扩展主要改 YAML 而非 env
#     （本节末尾「RAG 场景参数」与 chatbot 区 `CHATBOT_PROMPT_DEFAULT_VERSION` 等除外）。
#
# 【数值钳制】未设置的环境变量走代码默认值；读取后常见下限：`get_app_config().analysis` 构造处对整数/浮点有
#   max/min 限制（与下表「范围」一致），避免误配导致异常。
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# A. 接口层默认（请求体 `options` 未填时由 `AnalysisService._apply_defaults_*` 补齐）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# | 变量 | 作用 | 取值范围 / 说明 |
# |------|------|----------------|
# | ANALYSIS_DEFAULT_REPORT_TEMPLATE | 报告模板标识默认 | 字符串，默认 standard；与 `_build_structured_report` 分支相关 |
# | ANALYSIS_DEFAULT_CHART_MODE | 图表输出策略默认 | `auto` \| `minimal` \| `off`；非法值回落为 config 默认 `auto` |
# | ANALYSIS_DEFAULT_REPORT_STYLE | 报告风格默认 | 字符串，如 standard |
# | ANALYSIS_DEFAULT_MAX_NL2SQL_CALLS | 单次 nl2sql 分析最多子查询条数 | 整数 ≥1，代码 `max(1, env)`，与 `plan_tasks` 截断一致 |
# | ANALYSIS_DEFAULT_MAX_ROWS_PER_QUERY | 每条 NL2SQL 返回行上限 | 整数 ≥50，代码 `max(50, env)` |
# | ANALYSIS_DEFAULT_MAX_SUGGESTIONS | 建议列表条数上限 | 1～20，代码 `max(1, min(20, env))` |
# | ANALYSIS_STRICT_BY_DEFAULT | 是否默认开启严格质量门 | `true`\|`false`；true 时 payload/nl2sql 不达标可失败，见 `_evaluate_*_quality` |
# ANALYSIS_DEFAULT_REPORT_TEMPLATE=standard
# ANALYSIS_DEFAULT_CHART_MODE=auto
# ANALYSIS_DEFAULT_REPORT_STYLE=standard
# ANALYSIS_DEFAULT_MAX_NL2SQL_CALLS=6
# ANALYSIS_DEFAULT_MAX_ROWS_PER_QUERY=2000
# ANALYSIS_DEFAULT_MAX_SUGGESTIONS=8
# ANALYSIS_STRICT_BY_DEFAULT=false

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# B. Trace 归档（`ANALYSIS_TRACE_*`；`GET /analysis/traces*` 数据源）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# | 变量 | 作用 | 取值范围 / 说明 |
# |------|------|----------------|
# | ANALYSIS_TRACE_BACKEND | 归档实现 | `redis` \| `memory` \| `es`；别名 `easysearch`/`elasticsearch`→内部按 `es` |
# | ANALYSIS_TRACE_TTL_MINUTES | 记录生存时间 | 分钟，整数 ≥10；Redis 为 key TTL；ES 为文档字段 `expires_at_ms` |
# | ANALYSIS_TRACE_MAX_ITEMS | 索引裁剪规模 | 整数 ≥100；**仅 Redis** ZSET 与类型索引裁剪；ES 不按此项自动删索引 |
# | ANALYSIS_TRACE_TREND_CACHE_TTL_SECONDS | 趋势 API 进程内缓存 | 秒，≥1；见 `AnalysisService.get_trace_trend` |
# | ANALYSIS_TRACE_LAZY_CLEANUP_BATCH_SIZE | Redis 孤儿索引清理批量 | 整数 ≥20；`_lazy_cleanup_orphans` |
# | ANALYSIS_TRACE_ES_* | ES/EasySearch 连接 | `backend=es` 时生效；hosts 逗号分隔；认证与 `RAG_ES_*` 可回落共用 |
# redis 依赖全局 `REDIS_URL`（同文件其它区）；memory 仅单机调试。
# ANALYSIS_TRACE_BACKEND=redis
# ANALYSIS_TRACE_TTL_MINUTES=1440
# ANALYSIS_TRACE_MAX_ITEMS=10000
# ANALYSIS_TRACE_TREND_CACHE_TTL_SECONDS=30
# ANALYSIS_TRACE_LAZY_CLEANUP_BATCH_SIZE=200
# ANALYSIS_TRACE_ES_HOSTS=http://localhost:9200
# ANALYSIS_TRACE_ES_INDEX=analysis_trace_archive
# ANALYSIS_TRACE_ES_VERIFY_CERTS=false
# ANALYSIS_TRACE_ES_TIMEOUT_SECONDS=10
# ANALYSIS_TRACE_ES_USERNAME=
# ANALYSIS_TRACE_ES_PASSWORD=
# ANALYSIS_TRACE_ES_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# C. 质量门阈值（[0,1] 浮点，`AnalysisConfig` 加载时钳制到合理区间；用于 strict）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# | 变量 | 作用 | 典型语义 |
# |------|------|----------|
# | ANALYSIS_PAYLOAD_* | payload 模式 | 时间窗覆盖率下限、数值异常率上限、关键字段缺失率上限；`_evaluate_payload_quality` |
# | ANALYSIS_NL2SQL_* | nl2sql 模式 | 同上 + 全失败/关键步骤失败等；`_evaluate_nl2sql_quality` |
# ANALYSIS_PAYLOAD_TIME_WINDOW_COVERAGE_MIN=0.6
# ANALYSIS_PAYLOAD_ANOMALY_RATE_MAX=0.2
# ANALYSIS_PAYLOAD_MISSING_KEY_RATE_MAX=0.3
# ANALYSIS_NL2SQL_TIME_WINDOW_COVERAGE_MIN=0.5
# ANALYSIS_NL2SQL_ANOMALY_RATE_MAX=0.25
# ANALYSIS_NL2SQL_MISSING_KEY_RATE_MAX=0.35

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# D. NL2SQL 路径 · LLM 分阶段规划（`AnalysisGraphRunner._nl2sql_run_intent_llm` / `_nl2sql_run_plan_llm`）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# | 变量 | 作用 | 取值 |
# |------|------|------|
# | ANALYSIS_NL2SQL_LLM_PLANNER_ENABLED | 是否跑意图+数据计划两阶段 LLM | `true`\|`false`；false 时图节点仍执行但走降级逻辑，仅用 `analysis_plan_*` 与内置默认 |
# ANALYSIS_NL2SQL_LLM_PLANNER_ENABLED=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# E. LangGraph checkpoint（`AnalysisGraphRunner._build_analysis_checkpointer`）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# | 变量 | 作用 | 取值 / 依赖 |
# |------|------|-------------|
# | ANALYSIS_CHECKPOINT_BACKEND | 图状态后端 | `none`\|`memory`\|`redis`；非法或依赖缺失→等价 none |
# | ANALYSIS_CHECKPOINT_REDIS_URL | RedisSaver 连接串 | 仅 `backend=redis` 时必填；可与 `REDIS_URL` 不同 DB |
# | ANALYSIS_CHECKPOINT_NAMESPACE | 逻辑命名空间 | 字符串；日志与运维区分业务 |
# 每次请求独立 `thread_id`（`run_with_*` 内 `analysis:payload:{uuid}` / `analysis:nl2sql:{uuid}`），元数据进 `trace.execution_summary`。
# ANALYSIS_CHECKPOINT_BACKEND=none
# ANALYSIS_CHECKPOINT_REDIS_URL=redis://redis:6379/2
# ANALYSIS_CHECKPOINT_NAMESPACE=analysis_graph

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# F. 与综合分析相关的 RAG 检索参数（`app/core/config.py` → `RAGSceneProfilesConfig`）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 下列变量 **不是** `ANALYSIS_` 前缀，但被 `AnalysisGraphRunner` 间接使用：
#   - `RAG_SCENE_NL2SQL_*`：`scene="nl2sql"`，用于「规划前」检索（`_retrieve_plan_rag` → `plan_context_rag` 节点）。
#   - `RAG_SCENE_ANALYSIS_*`：`scene="analysis"`，用于「结论前」业务 RAG（`_retrieve_business_rag` → `rag_enrichment` 节点）。
# 默认值见本文件「RAG 场景化 TopK」小节；与 `HybridRAGService` / `RAGService._get_scene_profile` 对齐。

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# G. 提示词与鉴权（非 ANALYSIS_ 前缀，但与综合分析联调强相关）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# - 综合分析模板文件：默认 `configs/prompts.yaml`（顶级键 = `PromptTemplateRegistry` 的 scene；详见该文件头部注释）。
#   扩展数据计划请增加/修改 `analysis_plan_<analysis_type>` JSON 数组；LLM 分阶段见 `analysis_intent` / `analysis_data_plan`。
# - HTTP 鉴权：`/analysis/*` 与其它 API 相同，请求头 `Authorization: Bearer <SERVICE_API_KEY>`（见本文件 SERVICE_API_KEY 及部署说明）。
# - NL2SQL 主链路 SQL 生成使用 prompts 中 `nl2sql` 段，默认版本见 `NL2SQL_PROMPT_DEFAULT_VERSION`（chatbot 区附近注释）。
