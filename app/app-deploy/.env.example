# =============================================================================
# 应用部署环境变量模板（请复制为同目录 .env 再修改）
# =============================================================================
#
# 【重要】两套消费者 · 配置时不要混用语义
#
#   (1) Docker Compose 在「宿主机」解析（写进 docker-compose.yml 的 ${VAR}）
#       仅影响 compose 本身：端口映射、external 网络名、数据卷源路径、
#       models-app-gpu 的 NVIDIA_VISIBLE_DEVICES 注入值 等。
#       见本文件末尾「━━ Compose 专用 ━━」段。
#
#   (2) 应用进程在「容器内」读取（app/core/config.py 的 os.getenv）
#       通过 compose 的 env_file 整文件注入，应用不会自行 load_dotenv 读磁盘。
#       密钥、LLM/RAG/DB 等均以容器内环境为准。
#
# 【策略】
#   - 开发：本目录一份 .env，勿提交真实密码。
#   - 生产：用 CI/Secret 注入相同键名，或挂载只读 env；与 EasySearch、vLLM 侧配置保持一致。
#   - 与 rag_db-deploy 对齐：RAG_ES_* 与 project-env/rag-es.env.example、库侧账号一致。
#
# =============================================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 入口与并发（由 config.py / uvicorn 使用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用部署环境标记（当前仅作为配置元数据，代码未做 dev/prod 分支逻辑）
APP_ENV=prod
# Uvicorn worker 数量；docker-compose 内 command 使用 UVICORN_WORKERS
UVICORN_WORKERS=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 日志
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LOG_LEVEL=INFO
LOG_JSON=false
# stdout 日志（Docker logs）保持启用；以下参数用于额外开启应用内部文件日志（按大小轮转）
LOG_FILE_ENABLED=true
# 默认文件路径（容器内）；开启 LOG_FILE_ENABLED=true 时生效
LOG_FILE=/workspace/logs/app.log
# 单个日志文件最大字节数（默认 100MB）
LOG_FILE_MAX_BYTES=104857600
# 保留的历史文件数（不含当前 app.log）
LOG_FILE_BACKUP_COUNT=10
# 轮转后的历史日志是否 gzip 压缩
LOG_FILE_COMPRESS=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 大模型（统一指向 vllm-deploy，OpenAI 兼容 /v1）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 必须使用「容器间」可解析主机名：默认 vllm-service，勿用 127.0.0.1 指宿主机上的 vLLM
LLM_DEFAULT_MODEL=qwen2.5-vl-7b-instruct
# OpenAI 兼容根路径（结尾保留 /v1）
LLM_DEFAULT_ENDPOINT=http://vllm-service:8000/v1
# 若 vLLM 开启 API Key，在此配置；未启用可留空
LLM_DEFAULT_API_KEY=
# 若 vLLM 启用了 api-key，在此与 vLLM 侧填相同值

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · EasySearch / RAG（与 rag_db-deploy、HTTPS/TLS 策略一致）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RAG_VECTOR_STORE_TYPE=es
# 可配置多个主机，逗号分隔，如：https://rag-easysearch:9200,https://rag-es-backup:9200
RAG_ES_HOSTS=https://rag-easysearch:9200
# EasySearch 账号（与 rag_db-deploy/.env 保持一致）
RAG_ES_USERNAME=admin
# EasySearch 密码（与 rag_db-deploy/.env 保持一致）
RAG_ES_PASSWORD=ChangeMe_123!
# 若使用 API Key，可替代账号密码；留空表示不用
RAG_ES_API_KEY=
# 自建证书 / 内网 HTTPS 时常为 false；公网受信 CA 可改为 true
RAG_ES_VERIFY_CERTS=false
# ES/EasySearch 请求超时（秒）
RAG_ES_REQUEST_TIMEOUT=30

# 主知识库索引（chunks）
RAG_ES_INDEX_NAME=rag_knowledge_base
# 主知识库别名（应用查询通常走 alias）
RAG_ES_INDEX_ALIAS=rag_knowledge_base
# 索引版本号（用于迁移）
RAG_ES_INDEX_VERSION=1
# 启动时是否自动检查并迁移索引版本
RAG_ES_AUTO_MIGRATE_ON_START=true
# 向量字段名（需与摄入/查询逻辑一致）
RAG_ES_VECTOR_FIELD=embedding
# 文档元信息索引（文档级状态、来源、版本等）
RAG_ES_DOCS_INDEX_NAME=rag_docs
RAG_ES_DOCS_INDEX_ALIAS=rag_docs_current
RAG_ES_DOCS_INDEX_VERSION=1
# 异步作业索引（摄入任务、状态追踪等）
RAG_ES_JOBS_INDEX_NAME=rag_jobs
RAG_ES_JOBS_INDEX_ALIAS=rag_jobs_current
RAG_ES_JOBS_INDEX_VERSION=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · Redis 会话（compose 服务名 redis，勿写成 127.0.0.1）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
REDIS_URL=redis://redis:6379/0
# 会话过期时间（分钟），0 或负数可视为不过期（按代码实现）
CONV_SESSION_TTL_MINUTES=60
# 单会话最大保留消息数（超出会裁剪历史）
CONV_MAX_HISTORY_MESSAGES=50

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 业务库（NL2SQL 等）— DB_URL 优先于 DB_* 拼接（见 config.py）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MySQL 在宿主机：compose 已加 extra_hosts host.docker.internal
DB_HOST=host.docker.internal
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=aishare
# 密码含 @ # 等请 URL 编码写入 DB_URL；或不设 DB_URL 仅用 DB_*（按代码逻辑）
DB_URL=mysql+aiomysql://root:your_mysql_password@host.docker.internal:3306/aishare

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 嵌入与重排（HF 缓存卷见 docker-compose huggingface-cache）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# 优先使用本地模型目录（离线部署推荐）；设置后优先于 EMBEDDING_MODEL_NAME
# EMBEDDING_MODEL_PATH=/models/bge-small-zh-v1.5
EMBEDDING_MODEL_PATH=/workspace/models/embeddings/bge-small-zh-v1.5
RAG_RERANKER_MODEL_NAME=BAAI/bge-reranker-large
# 本地重排模型路径（离线部署推荐）；设置后优先于 RAG_RERANKER_MODEL_NAME
# RAG_RERANKER_MODEL_PATH=/models/bge-reranker-large

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · RAG 行为（更多键见 app/core/config.py）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RAG_ENABLE_BY_DEFAULT=true
# 上下文开关默认值（接口请求未显式传参时生效）
RAG_ENABLE_CONTEXT_BY_DEFAULT=true
# 传统检索 TopK（各场景还可被 scene 配置覆盖）
RAG_TOP_K=5
# 是否启用混合检索（语义 + 关键词 + RRF + 重排）
RAG_HYBRID_ENABLED=true
# 是否启用 Agentic 检索策略（多步规划检索）
RAG_AGENTIC_ENABLED=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · MinerU（mineru-deploy 独立栈；须与 docker-compose 中 mineru-external 同时使用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 是否启用 MinerU 解析（接入代码落地后生效；未实现前保持 false）
MINERU_ENABLED=false
# 容器内访问 mineru-api：端口必须是 MinerU 容器内监听端口（本栈为 8000），与 vLLM 容器内 8000 不冲突
# 勿使用宿主机映射端口 MINERU_PORT（如 8009）；详见 mineru-deploy/README.md §7
MINERU_BASE_URL=http://mineru-api:8000
# 单次解析 HTTP 超时（秒）；大扫描 PDF 建议 600～3600，按 SLA 调整
MINERU_TIMEOUT_S=1200
# 应用侧并发调用上限（保护同机资源；与 mineru-deploy 内并发策略对齐）
MINERU_MAX_CONCURRENT=1
# 应用容器内与 mineru-deploy 共享 IO 的挂载点（与 docker-compose 中卷目标路径一致）
MINERU_IO_CONTAINER_PATH=/workspace/mineru-io
# mineru-api /file_parse 表单：backend、parse_method（扫描件建议 ocr）、语言
MINERU_BACKEND=pipeline
MINERU_PARSE_METHOD=ocr
MINERU_LANGUAGE=ch
# CPU 压力控制：可关闭高开销模块（复杂公式/表格）
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
# 大 PDF 分段解析：0=不分段；建议先从 50~100 页/批试起
MINERU_PAGE_BATCH_SIZE=0
# 抽样页平均可提取字符低于该阈值则视为扫描 PDF，走 MinerU（文字 PDF 仍走 pypdf）
MINERU_PDF_SCANNED_MAX_AVG_CHARS=40
# 多 worker 时与 REDIS_URL 配合的全局并发池键前缀
MINERU_REDIS_SEM_KEY_PREFIX=mineru:ingest
# 一般无需修改
# MINERU_FILE_PARSE_PATH=/file_parse
# 与 mineru-deploy 中 MINERU_API_OUTPUT_ROOT 最后一级目录一致（共享 IO 卷上的子目录名）
# MINERU_DISK_FALLBACK_SUBDIR=mineru-output

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · GraphRAG（默认关；需独立 Neo4j 时再配置）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GRAPH_RAG_ENABLED=false
# Neo4j Bolt 地址（容器间建议使用服务名）
# NEO4J_URI=bolt://graph-neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · 可观测性（可选）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 应用进程 · FAISS 向量库（与 ES 二选一；开发单机可用）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAG_VECTOR_STORE_TYPE=faiss
# RAG_FAISS_INDEX_DIR=/data/faiss

## =============================================================================
## ━━ Compose 专用（宿主机解析；勿与「仅应用读取」混淆）━━━━━━━━━━━━━━━━━━━━
## =============================================================================
## 下列变量在 docker-compose.yml 中通过 ${VAR:-默认值} 使用；不会自动被 app/core/config.py 使用，
## 除非同时作为普通环境变量注入容器（Compose env_file 会整份注入，应用若「恰巧」同名才会读到——
## 下列键名仅为避免冲突，与业务无关，应用代码可忽略）。
##
## APP_PORT                models-app 映射到宿主机的端口
## APP_PORT_GPU            models-app-gpu 映射到宿主机的端口（profile small-model-gpu）
## VLLM_DOCKER_NETWORK     已存在的 Docker 网络名，用于连接 vLLM
## RAG_DOCKER_NETWORK      已存在的 Docker 网络名，用于连接 EasySearch
## MINERU_DOCKER_NETWORK   已存在的 Docker 网络名，用于连接 mineru-api（mineru-deploy）
## MINERU_IO_HOST_PATH     宿主机目录，与 mineru-deploy 的 MINERU_IO_HOST_PATH 必须相同；
##                         bind 到应用容器 MINERU_IO_CONTAINER_PATH（默认 /workspace/mineru-io）
## GRAPH_DOCKER_NETWORK    已存在的 Docker 网络名，用于连接 Neo4j（GraphRAG）
## SMALL_MODEL_WEIGHTS_HOST_PATH
##                         宿主机绝对路径 → 只读挂载到 GPU 容器 /workspace/models/small
## SMALL_MODEL_NVIDIA_VISIBLE_DEVICES
##                         传入 GPU 容器的 NVIDIA_VISIBLE_DEVICES（默认 all）
## =============================================================================

APP_PORT=8083

# 须在「已存在」的外部网络；与 vllm-deploy、rag_db-deploy 实际名称一致（docker network ls）
VLLM_DOCKER_NETWORK=docker_vllm-network
RAG_DOCKER_NETWORK=ai-stack
# MinerU 外部网络名，须与 mineru-deploy/.env 中 MINERU_NETWORK_NAME 一致（docker network ls 可见）。
# 若尚未部署 mineru-deploy，可先占位：docker network create mineru-stack
MINERU_DOCKER_NETWORK=mineru-stack
# 与 mineru-deploy/.env 中 MINERU_IO_HOST_PATH 保持一致（Linux 示例）；未配置时使用 compose 占位卷 mineru-io-dummy
# MINERU_IO_HOST_PATH=/data/mineru/io
# GraphRAG / Neo4j 外部网络名，需与 graphrag_db-deploy/.env 中 NEO4J_NETWORK 一致
GRAPH_DOCKER_NETWORK=graph-stack

# ---------- profile: small-model-gpu（docker compose --profile small-model-gpu）----------
# GPU 版 API 对外端口（避免与 APP_PORT 冲突）
APP_PORT_GPU=8081
# 仅起 GPU 实例且占 8080：先 stop models-app，再设 APP_PORT_GPU=8080
SMALL_MODEL_NVIDIA_VISIBLE_DEVICES=all
# 示例 Linux：SMALL_MODEL_WEIGHTS_HOST_PATH=/opt/small-model-weights
# 示例 Windows：SMALL_MODEL_WEIGHTS_HOST_PATH=F:/weights/small
# 不设置或整行不写：compose 使用占位卷 small-model-weights-dummy（无真实权重，仅便于调试 compose）
