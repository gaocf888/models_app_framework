# 配置优先级1
# 当前vllm-deploy/ 的全部配置文件如下（按照配置生效优先级排序）：
# .env
# config/models.yaml
# config/vllm.yaml

# 环境变量配置模板（复制为 vllm-deploy/.env 后按需修改）

# ---------- 镜像构建（docker compose build）----------
# 基础镜像：英伟达默认可不设置；国产算力请改为厂商提供的本地/私有仓库标签
# BASE_IMAGE=registry.example.com/accelerator/vllm-stack:2025.01
BASE_IMAGE=cr.metax-tech.com/public-ai-release/maca/vllm-metax:0.17.0-maca.ai3.5.3.307-torch2.8-py312-kylinv11-amd64

# 依赖配置：full = 安装 requirements.txt（含 vLLM，默认针对nvidia显卡）；extras = 仅 requirements-extras.txt（针对国产卡，厂商已预装 vLLM/torch 时使用）
# VLLM_REQUIREMENTS_PROFILE=full
VLLM_REQUIREMENTS_PROFILE=extras

# 构建产物镜像名
VLLM_IMAGE=vllm-service:latest

# ---------- 运行期 ----------
# 部署平台（与 deploy.sh --platform 一致）：nvidia / cambricon / mthreads(沐曦) / ascend
# VLLM_PLATFORM=nvidia
VLLM_PLATFORM=mthreads

# MODEL_PRESET=qwen2.5-vl-7b
MODEL_PRESET=qwen3-27b

VLLM_HOST=0.0.0.0
VLLM_PORT=8000

# 模型目录挂载（宿主机路径 -> 容器 /workspace/models）
# 默认建议：/opt/models/llm
MODEL_PATH=/opt/models/llm

# GPU 可见设备（按卡型设置；start.py 会根据探测到的设备读取对应变量）
# - 英伟达(cuda): 使用 CUDA_VISIBLE_DEVICES（例如 0 或 0,1）
# - 昇腾(npu): 使用 ASCEND_RT_VISIBLE_DEVICES
# - 寒武纪(mlu): 使用 MLU_VISIBLE_DEVICES
# - 沐曦/燧原(gcu): 使用 MX_VISIBLE_DEVICES
# - Intel(xpu): 使用 XPU_VISIBLE_DEVICES
# 注意：
# 1) 国产环境可保留 CUDA_VISIBLE_DEVICES，但最终以对应厂商变量为准
# 2) 若未显式设置厂商变量，start.py 默认使用单卡 0
# CUDA_VISIBLE_DEVICES=0
# ASCEND_RT_VISIBLE_DEVICES=0
# cambricon 平台建议显式配置：
# MLU_VISIBLE_DEVICES=0
# mthreads 平台建议显式配置：
MX_VISIBLE_DEVICES=0,1
# XPU_VISIBLE_DEVICES=0

# 仅 nvidia 平台使用：占用 GPU 数量（all 或数字）
# GPU_DEVICE_COUNT=all

# 根据显卡数量配置
# TENSOR_PARALLEL_SIZE=1
TENSOR_PARALLEL_SIZE=2
# GPU_MEMORY_UTILIZATION=0.92
# MAX_MODEL_LEN=8192

LOG_LEVEL=INFO
# STARTUP_WAIT_TIMEOUT=1200

# 可选：媒体挂载（compose 中 MEDIA_PATH，默认 docker/media）
# MEDIA_PATH=./media

# WORKSPACE=/workspace
