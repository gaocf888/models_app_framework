# 环境变量配置模板
# 复制为 .env 并修改

# 模型预设 (qwen2.5-7b, qwen2.5-32b, qwen2-vl-7b, llama3-8b, deepseek-v2)
MODEL_PRESET=qwen2.5-7b

# 服务配置
VLLM_HOST=0.0.0.0
VLLM_PORT=8000

# 模型路径（覆盖预设配置）
# MODEL_PATH=/absolute/path/to/model

# GPU 配置
CUDA_VISIBLE_DEVICES=0,1
TENSOR_PARALLEL_SIZE=1

# 日志级别
LOG_LEVEL=INFO

# 工作目录（可选，默认使用项目根目录）
# WORKSPACE=/workspace