# Neo4j / GraphRAG 容器部署环境模板
#
# 说明：
# - 本目录负责部署 Neo4j 实例，供应用的 GraphRAG 能力使用；
# - 应用侧通过项目内 app/app-deploy 下的 .env / project-env 读取 NEO4J_* 变量接入；
# - 请复制为 .env 并按实际环境修改后再使用 docker compose。

# =========================
# 基础镜像与容器命名
# =========================

# 官方镜像（社区版）：neo4j:5.x。需要企业版或插件时可自行替换。
NEO4J_IMAGE=neo4j:5.24.0-community

# Compose 服务名 / 容器名，与应用侧 NEO4J_URI 主机名一致
NEO4J_CONTAINER_NAME=graph-neo4j
NEO4J_SERVICE_NAME=neo4j

# 外部网络名（供应用加入），默认 graph-stack。若修改，请与 app/app-deploy/.env 中 GRAPH_DOCKER_NETWORK 保持一致。
NEO4J_NETWORK=graph-stack

# =========================
# 访问端口
# =========================

# Bolt 协议（应用 GraphRAG 使用）：默认 7687
NEO4J_BOLT_PORT=7687

# HTTP 管理接口（浏览器 / Web UI）：默认 7474（可按需改为宿主 7474 或内网专用端口）
NEO4J_HTTP_PORT=7474

# =========================
# 认证与数据库
# =========================

# 默认账号与密码（首次启动时生效）。生产环境务必修改为强密码。
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=ChangeMe_123!

# 默认数据库名称（Neo4j 5 支持多库，这里保持与 app/core/config.py 默认一致）
NEO4J_DATABASE=neo4j

# 对外宣告的主机名（用于集群 / 跨主机时），单机默认与容器名一致即可
NEO4J_ADVERTISED_HOST=graph-neo4j

# =========================
# 数据卷
# =========================

# 数据卷名称，承载 /data（图数据）、/logs 等，避免容器销毁后数据丢失。
NEO4J_DATA_VOLUME=graph_neo4j_data

