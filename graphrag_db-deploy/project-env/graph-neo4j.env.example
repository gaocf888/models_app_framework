# 应用侧 GraphRAG 接入 Neo4j 的环境模板
#
# 说明：
# - 本文件用于 app/app-deploy 等应用栈接入 Neo4j（GraphRAG）；
# - 部署 Neo4j 自身使用 graphrag_db-deploy/.env + docker-compose.neo4j.yml；
# - 应用进程真正读的是 app/app-deploy/.env 中的 NEO4J_*，本文件可作为那里的“项目级模板”。

# =========================
# 是否启用 GraphRAG
# =========================

GRAPH_RAG_ENABLED=true

# =========================
# 连接信息（与 graphrag_db-deploy/.env 保持一致）
# =========================

# Bolt URI，容器间推荐使用服务名 / 容器名（假定应用与 Neo4j 在同一 Docker 网络）。
NEO4J_URI=bolt://graph-neo4j:7687

# 账号与密码：与 Neo4j 容器 NEO4J_AUTH 中的 NEO4J_USERNAME/NEO4J_PASSWORD 相同
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=ChangeMe_123!

# 默认数据库名
NEO4J_DATABASE=neo4j

# 可选：通过外部 YAML 定义图 Schema 时的配置文件路径（容器内路径）
# GRAPH_SCHEMA_CONFIG_PATH=/workspace/config/graph_schema.yaml

