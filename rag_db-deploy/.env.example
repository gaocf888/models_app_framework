# EasySearch container image (replace with your registry image)
# Default uses Elasticsearch image because EasySearch is ES API compatible.
# EASYSEARCH_IMAGE=elasticsearch:8.13.4
EASYSEARCH_IMAGE=infinilabs/easysearch:2.1.1

# Container/service names
EASYSEARCH_CONTAINER_NAME=rag-easysearch
EASYSEARCH_SERVICE_NAME=easysearch
EASYSEARCH_NETWORK=ai-stack

# Access
EASYSEARCH_PORT=9200
EASYSEARCH_USERNAME=elastic
EASYSEARCH_PASSWORD=changeme

# JVM and storage
EASYSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
EASYSEARCH_DATA_VOLUME=rag_easysearch_data

# Cluster
EASYSEARCH_CLUSTER_NAME=rag-es-cluster
EASYSEARCH_NODE_NAME=node-1
