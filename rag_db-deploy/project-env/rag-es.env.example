# =========================
# RAG storage type
# =========================
RAG_VECTOR_STORE_TYPE=es

# =========================
# EasySearch / Elasticsearch connection
# =========================
# Use container name in docker network, use localhost for local debugging.
RAG_ES_HOSTS=https://rag-easysearch:9200
RAG_ES_USERNAME=admin
# 建议替换为与你 EasySearch 实际 admin 相同的强密码
RAG_ES_PASSWORD=ChangeMe_123!
RAG_ES_API_KEY=
RAG_ES_VERIFY_CERTS=false
RAG_ES_REQUEST_TIMEOUT=30

# =========================
# Index naming and version
# =========================
RAG_ES_INDEX_NAME=rag_knowledge_base
RAG_ES_INDEX_ALIAS=rag_knowledge_base
RAG_ES_INDEX_VERSION=1
RAG_ES_AUTO_MIGRATE_ON_START=true
RAG_ES_VECTOR_FIELD=embedding

RAG_ES_DOCS_INDEX_NAME=rag_docs
RAG_ES_DOCS_INDEX_ALIAS=rag_docs_current
RAG_ES_DOCS_INDEX_VERSION=1

RAG_ES_JOBS_INDEX_NAME=rag_jobs
RAG_ES_JOBS_INDEX_ALIAS=rag_jobs_current
RAG_ES_JOBS_INDEX_VERSION=1
