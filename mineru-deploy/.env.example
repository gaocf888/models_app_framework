# =============================================================================
# MinerU 独立部署栈（mineru-deploy）— 与 rag_db-deploy、vllm-deploy 一样单独管理
# 使用：复制为 .env 后按内网环境修改；勿将含密码的 .env 提交仓库
# =============================================================================

# --- 镜像（须从内网镜像仓拉取；标签以你们选用的 MinerU 版本为准）---
MINERU_IMAGE=registry.example.com/ml/mineru-api:REPLACE_ME_TAG
MINERU_CONTAINER_NAME=mineru-api

# HTTP 端口（宿主机）
MINERU_PORT=8009

# --- 算力模式（与 docker compose 调用方式配合，见 README）---
# cpu：默认；仅使用 docker-compose.yml
# gpu：叠加 docker-compose.gpu.yml，并需本机已装 NVIDIA Container Toolkit
MINERU_DEVICE_MODE=cpu

# GPU 模式下可见 GPU（示例：单卡 0；多卡或隔离 vLLM 时请改为未占用设备）
MINERU_NVIDIA_VISIBLE_DEVICES=0

# --- 离线模型与配置（必看 README「离线模型」章节）---
# 宿主机上已下载好的模型根目录（只读挂载进容器）
MINERU_MODELS_HOST_PATH=/data/mineru/models

# 解析过程读写：上传 PDF、输出 Markdown 等（需与 models-app 约定为同一目录或子目录）
MINERU_IO_HOST_PATH=/data/mineru/io

# MinerU 工具配置 JSON（宿主机路径；内含 models-dir 等，须与离线目录一致）
MINERU_TOOLS_CONFIG_HOST_PATH=./config/mineru-tools.json

# 常见离线相关（具体键名以 MinerU 版本文档为准；无则留空或删除）
MINERU_MODEL_SOURCE=local
# 离线强化（与 docker-compose.yml 中环境变量一致；调试需联网时可改为 0）
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# --- 资源上限（docker-compose.yml 中 cpus / mem_limit；避免拖垮同机 vLLM / ES）---
MINERU_CPU_LIMIT=4.0
# 示例：8g、16g、32g（Docker 接受的内存单位写法）
MINERU_MEM_LIMIT=16g

# --- Docker 网络：供 models-app 以外部网络接入 ---
MINERU_NETWORK_NAME=mineru-stack
