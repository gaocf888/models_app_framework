# Build (source install)
MINERU_CPU_IMAGE=mineru-cpu:py311
MINERU_GPU_IMAGE=mineru-gpu:cu124
MINERU_CPU_PIP_SPEC=mineru[core]
MINERU_GPU_PIP_SPEC=mineru[core]
# Optional pip mirror:
# PIP_INDEX_URL=https://pypi.org/simple
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# GPU image build options:
INSTALL_CUDA_TORCH=1
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121

# Runtime
MINERU_CONTAINER_NAME=mineru-api
MINERU_PORT=8009

# GPU selector
MINERU_NVIDIA_VISIBLE_DEVICES=0

# Host paths (must exist)
MINERU_MODELS_HOST_PATH=/data/mineru/models
MINERU_IO_HOST_PATH=/data/mineru/io

# Online by default
MINERU_MODEL_SOURCE=modelscope
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
# Optional: MINERU_MODEL_SOURCE=modelscope

# Offline fallback:
# MINERU_MODEL_SOURCE=local
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# Resources
MINERU_CPU_LIMIT=4.0
MINERU_MEM_LIMIT=16g
# 线程数硬限制（避免 32 核机器被单任务打满）
OMP_NUM_THREADS=8
MKL_NUM_THREADS=8
OPENBLAS_NUM_THREADS=8
NUMEXPR_NUM_THREADS=8
TORCH_NUM_THREADS=8
TORCH_NUM_INTEROP_THREADS=2

# Network (must match models-app external network)
MINERU_NETWORK_NAME=mineru-stack

